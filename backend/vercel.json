{
  "version": 2,
  "installCommand": "python3 -m pip install --upgrade pip setuptools --break-system-packages && npm install",
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
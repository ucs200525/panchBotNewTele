{
  "version": 2,
  "buildCommand": "python3 -m pip install setuptools && npm install",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/bot-cron",
      "schedule": "0 0 * * *"
    }
  ]
}